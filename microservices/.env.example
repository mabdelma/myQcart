# Qlisted microservices — copy to .env and fill in.
# AUTH_SECRET MUST equal the monolith's JWT_SECRET so tokens verify across both.
AUTH_SECRET=
LOG_LEVEL=info

# Gateway fall-through target for paths not yet extracted (the monolith API).
# e.g. http://api:3001 once the services share a network with the monolith.
MONOLITH_URL=

# notifications SMTP (mirror the monolith's mailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Qlisted <noreply@qlisted.com>
