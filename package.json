{
  "name": "qcart",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:analyze": "vite-bundle-visualizer",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "cd server && npm test && cd .. && vitest run",
    "seed": "cd server && npm run seed",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ci": "playwright test --config=e2e/playwright.config.ts --reporter=github",
    "ci": "npm run lint && npx tsc --noEmit && npm run build && cd server && npx tsc --noEmit && npm test && cd .. && vitest run",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "node_modules/.bin/tsc --noEmit --pretty"
    ],
    "server/src/**/*.ts": [
      "cd server && node_modules/.bin/tsc --noEmit --pretty"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.58.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "dompurify": "^3.4.10",
    "lucide-react": "^0.344.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.15.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^8.0.14",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.8"
  }
}
