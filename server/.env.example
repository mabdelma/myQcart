# Server Configuration
PORT=3001
DATABASE_URL=postgresql://qcart:qcart@localhost:5434/qcart
JWT_SECRET=change-this-to-a-random-secret-in-production
CORS_ORIGIN=http://localhost:5173

# Stripe Configuration (get keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Sentry (optional - remove if not using)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=debug

# Resend (email) — optional, email disabled if empty
RESEND_API_KEY=
MAIL_FROM=noreply@qcart.app

# Redis (optional) — enables pub/sub for SSE across multiple server instances.
# Falls back to in-process EventEmitter if unset or unreachable.
REDIS_URL=
