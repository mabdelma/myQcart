# Server Configuration
PORT=3001
DATABASE_URL=postgresql://qcart:qcart@localhost:5434/qcart
JWT_SECRET=change-this-to-a-random-secret-in-production
CORS_ORIGIN=http://localhost:5173

# Stripe Configuration (get keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Sentry (optional - remove if not using)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=debug

# Email — SMTP (recommended for production) or Resend, falls back to maildump/ files in dev
# For local dev with no SMTP, emails are written to server/maildump/ as HTML files
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@qcart.app

# Resend (alternative email provider) — optional, used only if SMTP not configured
RESEND_API_KEY=

# Redis (required) — enables pub/sub for SSE across multiple server instances.
# Server will exit at startup if this is not set.
REDIS_URL=

# Web Push / VAPID keys (required for browser push notifications)
# Generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
