# ─── QCart production secrets (VPS) ──────────────────────────────────────────
# Copy to .env.prod on the VPS and fill in real values. NEVER commit .env.prod.
#   cp .env.prod.example .env.prod
# Used by: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.vps.yml ...

# Public domain (must have an A record → VPS IP, and a matching Caddy block).
DOMAIN=qlisted.com

# Postgres — use a strong password (this DB is private to the qcart stack).
POSTGRES_USER=qcart
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=qcart

# API auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Platform super admin — seeded once (idempotent) on first migrate run.
SUPER_ADMIN_EMAIL=superadmin@qlisted.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# Stripe — server-side secret + webhook signing secret (sk_live_… / whsec_…)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI assistant (admin copilot + customer chat + forecast narrative).
# Two ways to enable it — either is enough:
#   1. OpenAI: set OPENAI_API_KEY (data goes to OpenAI, pay per token).
#   2. LOCAL / self-hosted: run an OpenAI-compatible server and set OPENAI_BASE_URL
#      + OPENAI_MODEL — no key, no cost, nothing leaves your infrastructure.
#      Ollama:    OPENAI_BASE_URL=http://<host>:11434/v1   OPENAI_MODEL=llama3.1
#      llama.cpp / vLLM / LM Studio expose the same /v1 API.
# Leave both blank to hide the AI features entirely.
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Model — OpenAI default gpt-4o-mini; for local set your model (e.g. llama3.1, qwen2.5).
OPENAI_MODEL=
# Voice (Realtime) ordering needs OpenAI specifically (no local equivalent); default gpt-realtime.
OPENAI_REALTIME_MODEL=

# Google sign-in — OAuth 2.0 Web client ID from Google Cloud Console.
# Add qlisted.com (+ subdomains) to Authorized JavaScript origins.
# Without it the "Sign in with Google" button is hidden.
GOOGLE_CLIENT_ID=

# Stripe Billing — recurring Price IDs for SaaS subscription plans (price_…).
# Create products/prices in Stripe, then paste the Price IDs here. Without them,
# subscription checkout returns "plan has no Stripe price configured".
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# Sentry DSN (optional — leave empty to disable error monitoring)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email — SMTP (recommended) or Resend (alternative).
# Leave both SMTP_* and RESEND_API_KEY empty to disable outbound email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=QCart <noreply@qlisted.com>
RESEND_API_KEY=

# Redis — REQUIRED. Powers SSE pub/sub across multiple API instances.
# Uses the `redis://` scheme. Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://redis:6379

# CORS — frontend origin (should match the public domain)
CORS_ORIGIN=https://qlisted.com

# Stripe publishable key — BAKED INTO THE FRONTEND BUNDLE AT BUILD TIME (pk_live_…).
# Changing it requires rebuilding the frontend image.
VITE_STRIPE_KEY=

# VAPID keys for Web Push notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Twilio SMS — booking/guest confirmations. Leave blank to disable (messages are
# logged instead). Get these from https://console.twilio.com → Account + a
# Messaging-capable phone number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
