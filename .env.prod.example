# ─── QCart production secrets (VPS) ──────────────────────────────────────────
# Copy to .env.prod on the VPS and fill in real values. NEVER commit .env.prod.
#   cp .env.prod.example .env.prod
# Used by: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.vps.yml ...

# Public domain (must have an A record → VPS IP, and a matching Caddy block).
DOMAIN=qcart.gmtmall.com

# Postgres — use a strong password (this DB is private to the qcart stack).
POSTGRES_USER=qcart
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=qcart

# API auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Platform super admin — seeded once (idempotent) on first migrate run.
SUPER_ADMIN_EMAIL=superadmin@qcart.gmtmall.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# Stripe — server-side secret + webhook signing secret (sk_live_… / whsec_…)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI assistant (admin copilot + customer chat) — OpenAI.
# Without this key the AI features are simply hidden/disabled.
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini; e.g. gpt-4o).
OPENAI_MODEL=

# Stripe Billing — recurring Price IDs for SaaS subscription plans (price_…).
# Create products/prices in Stripe, then paste the Price IDs here. Without them,
# subscription checkout returns "plan has no Stripe price configured".
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# Sentry DSN (optional — leave empty to disable error monitoring)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email — SMTP (recommended) or Resend (alternative).
# Leave both SMTP_* and RESEND_API_KEY empty to disable outbound email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=QCart <noreply@qcart.gmtmall.com>
RESEND_API_KEY=

# Redis — REQUIRED. Powers SSE pub/sub across multiple API instances.
# Uses the `redis://` scheme. Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://redis:6379

# CORS — frontend origin (should match the public domain)
CORS_ORIGIN=https://qcart.gmtmall.com

# Stripe publishable key — BAKED INTO THE FRONTEND BUNDLE AT BUILD TIME (pk_live_…).
# Changing it requires rebuilding the frontend image.
VITE_STRIPE_KEY=

# VAPID keys for Web Push notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
