# ─── QCart production secrets (VPS) ──────────────────────────────────────────
# Copy to .env.prod on the VPS and fill in real values. NEVER commit .env.prod.
#   cp .env.prod.example .env.prod
# Used by: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.vps.yml ...

# Public domain (must have an A record → VPS IP, and a matching Caddy block).
DOMAIN=qcart.gmtmall.com

# Postgres — use a strong password (this DB is private to the qcart stack).
POSTGRES_USER=qcart
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=qcart

# API auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Stripe — server-side secret + webhook signing secret (sk_live_… / whsec_…)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key — BAKED INTO THE FRONTEND BUNDLE AT BUILD TIME (pk_live_…).
# Changing it requires rebuilding the frontend image.
VITE_STRIPE_KEY=
